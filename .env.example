# Supabase 配置
# 请在 Supabase 控制台创建项目后，将以下值替换为你的实际配置

# Supabase 项目 URL
VITE_SUPABASE_URL=https://your-project.supabase.co

# Supabase 匿名密钥（Anon Key）
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ==========================================
# 大模型 API 配置（AI 数据助手）
# ==========================================
# 支持 OpenAI-compatible 接口，如 Kimi(Moonshot)、OpenAI、DeepSeek 等
# 也可在前端通过 "AI 配置" 弹窗直接输入，无需修改此文件

# API Key
VITE_LLM_API_KEY=

# Base URL（示例为 Moonshot）
VITE_LLM_BASE_URL=https://api.moonshot.cn/v1

# 模型名称
VITE_LLM_MODEL=moonshot-v1-8k
